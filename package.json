{
  "name": "tasmota-sdk",
  "version": "1.0.0",
  "description": "A robust, type-safe TypeScript SDK for controlling Tasmota power sockets",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:clean": "rm -rf dist && npm run build",
    "build:examples": "tsc -p tsconfig.examples.json",
    "dev": "ts-node src/examples/basic-usage.ts",
    "dev:advanced": "ts-node src/examples/advanced-usage.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build:clean",
    "prepare": "npm run build"
  },
  "keywords": [
    "tasmota",
    "iot",
    "smart-home",
    "power-socket",
    "esp8266",
    "esp32",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "zod": "^3.22.0"
  },
  "overrides": {
    "minimatch": "^9.0.7"
  }
}
